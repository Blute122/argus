# --- Copy to .env and adjust. .env is gitignored. ---

# Relational metadata store (users, incidents, alerts, assets, hunts).
# Local dev without Docker uses SQLite. In Docker, point at Postgres:
# DATABASE_URL=postgresql+psycopg2://soc:soc@postgres:5432/soc
DATABASE_URL=sqlite:///./soc_simulator.db

# Log store (OpenSearch). When false, logs fall back to the relational DB so
# the app runs with zero extra infrastructure.
OPENSEARCH_ENABLED=false
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_VERIFY_CERTS=false
OPENSEARCH_INDEX_PREFIX=logs
OPENSEARCH_INDEX_PERIOD=day

# Keep the synthetic log generator running (training/demo/load).
# Set false in production so only real ingested logs appear.
DEMO_MODE=true

# --- Ingestion (Phase 2) ---
# HTTP ingest endpoints (/api/ingest, /api/ingest/bulk).
INGEST_ENABLED=true
# Syslog listener (UDP + TCP). Unprivileged port by default.
SYSLOG_ENABLED=false
SYSLOG_HOST=0.0.0.0
SYSLOG_UDP_PORT=5514
SYSLOG_TCP_PORT=5514
# File tailer: follow files and ingest new lines.
FILE_TAIL_ENABLED=false
FILE_TAIL_PATHS=
# Tenant stamped on every log (single-org self-host: leave as "default").
DEFAULT_TENANT=default

# Comma-separated allowed CORS origins. Use "*" for local dev only.
CORS_ORIGINS=*
